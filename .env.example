# ===== Database =====
DATABASE_URL=postgresql://ti_user:ti_password@postgres:5432/ti_katalog
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ===== Security =====
JWT_SECRET=change-this-very-long-random-string-in-production
ADMIN_PASSWORD=change-this-default-password

# ===== APIs =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# ===== R2 Storage =====
R2_BUCKET_URL=https://pub-xxxxx.r2.dev
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=katalog

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=/var/log/ti-katalog.log

# ===== Performance =====
WORKER_THREADS=4
REQUEST_TIMEOUT=60

# ===== Features =====
ENABLE_CACHE=true
ENABLE_VECTORDB=false
